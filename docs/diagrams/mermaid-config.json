{
  "theme": "base",
  "themeVariables": {
    "fontFamily": "Trebuchet MS, Segoe UI, Arial, sans-serif",
    "fontSize": "18px",
    "primaryTextColor": "#10233d",
    "primaryBorderColor": "#315ea8",
    "lineColor": "#4b5563",
    "secondaryColor": "#f3f4f6",
    "tertiaryColor": "#ffffff",
    "background": "#ffffff",
    "mainBkg": "#ffffff",
    "clusterBkg": "#f8fafc",
    "clusterBorder": "#cbd5e1"
  },
  "flowchart": {
    "curve": "basis",
    "nodeSpacing": 45,
    "rankSpacing": 55,
    "padding": 18,
    "htmlLabels": true
  },
  "sequence": {
    "diagramMarginX": 40,
    "diagramMarginY": 20,
    "actorMargin": 60,
    "width": 180,
    "messageMargin": 30,
    "mirrorActors": false
  }
}